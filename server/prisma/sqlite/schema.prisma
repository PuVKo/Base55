// Локально SQLite; структура полей совпадает с postgres для одного Prisma Client при смене DATABASE_URL.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum AuthTokenType {
  VERIFY_EMAIL
  RESET_PASSWORD
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  incomplete
}

enum BillingEventType {
  checkout_created
  payment_succeeded
  payment_canceled
  recurring_charge
  recurring_failed
  subscription_canceled
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  /// Логин для входа и отображения (уникальный, нижний регистр)
  login            String?   @unique
  passwordHash     String
  emailVerifiedAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  /// Настройки UI (плитки, панель фильтров) — JSON, см. clientUi на клиенте
  uiPrefs          Json?
  bookings         Booking[]
  fieldDefinitions FieldDefinition[]
  authTokens       AuthToken[]
  subscriptions    Subscription[]
  billingEvents    BillingEvent[]
}

model AuthToken {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      AuthTokenType
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime       @default(now())

  @@index([userId, type])
}

model Booking {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model FieldDefinition {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String
  label     String
  type      String
  sortOrder Int      @default(0)
  system    Boolean  @default(false)
  visible   Boolean  @default(true)
  iconKey   String?
  options   Json?

  @@unique([userId, key])
  @@index([userId])
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  planCode           String
  amountMinor        Int
  currency           String             @default("RUB")
  billingInterval    String             @default("month")
  status             SubscriptionStatus @default(incomplete)
  paymentMethodId    String?
  yookassaCustomerId String?
  lastPaymentId      String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  nextBillingAt      DateTime?
  cancelAtPeriodEnd  Boolean            @default(false)
  canceledAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  billingEvents      BillingEvent[]

  @@index([userId, status])
  @@index([nextBillingAt, status])
}

model BillingEvent {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId    String?
  subscription      Subscription?    @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  type              BillingEventType
  status            String?
  yookassaEventId   String?
  yookassaPaymentId String?
  idempotencyKey    String?
  payload           Json?
  processedAt       DateTime?
  createdAt         DateTime         @default(now())

  @@unique([yookassaEventId])
  @@unique([idempotencyKey])
  @@index([userId, type])
  @@index([subscriptionId, createdAt])
  @@index([yookassaPaymentId])
}
