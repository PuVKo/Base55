# Обязательно на локалке

DATABASE_URL="file:./dev.db"
PORT=3001
SESSION_COOKIE_SECURE=0
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=1
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
OPENROUTER_API_KEY=
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=http://localhost:5174/settings
YOOKASSA_WEBHOOK_SECRET=
YOOKASSA_WEBHOOK_ALLOWED_IPS=
YOOKASSA_TEST_MODE=true

# -----------------------------------------------------------------------------

# ПРОД

NODE_ENV=production
DATABASE_URL=
SESSION_SECRET=
APP_PUBLIC_URL=
PORT=
SESSION_COOKIE_SECURE=
CORS_ALLOW_LOCALHOST=0
EXPOSE_SERVER_ERRORS=0
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=1
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
CORS_ORIGINS=
OPENROUTER_API_KEY=
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=
YOOKASSA_WEBHOOK_SECRET=
YOOKASSA_WEBHOOK_ALLOWED_IPS=
YOOKASSA_TEST_MODE=false

# =============================================================================
# Описание и рекомендации
# =============================================================================
#
# Общее
#   Скопируйте нужный блок выше в server/.env. Секреты не коммитьте.
#   После смены SQLite ↔ Postgres выполните: cd server && node scripts/prisma-with-schema.mjs generate
#
# DATABASE_URL — строка Prisma. Локально чаще SQLite (file:./dev.db). На сервере — Postgres с sslmode=require.
#
# PORT — локально оставьте 3001 под прокси Vite. На Timeweb Apps часто не задают: платформа задаёт порт (часто 8080).
#   Если в окружении Postgres *.twc1.net и в .env остался PORT=3001 с локального шаблона, env.js может сбросить PORT.
#
# SESSION_COOKIE_SECURE — при HTTP (локалка) обычно 0. На проде за HTTPS можно не задавать: в production cookie secure по умолчанию.
#
# SESSION_SECRET — на проде задайте случайную строку ≥16 символов. Без неё сервер стартует с производным секретом (см. session.js).
#
# APP_PUBLIC_URL — публичный URL фронта без завершающего /. Письма (регистрация, сброс пароля), CORS, OpenRouter referer.
#
# NODE_ENV=production — типично на хостинге; влияет на cookie secure, CSP, маскировку ошибок в ответах API.
#
# CORS_ORIGINS — дополнительные origins через запятую (без пробелов вокруг URL). См. также устаревший алиас BOOKING_CORS_ORIGIN в index.js — то же самое, лучше задавать CORS_ORIGINS.
#
# CORS_ALLOW_LOCALHOST — по умолчанию localhost разрешён. На проде часто ставят 0.
#
# Важно: CORS относится только к запросам браузера к API. На доставку писем (SMTP/RuSender) CORS не влияет.
#
# EXPOSE_SERVER_ERRORS — в production текст исключений в JSON клиенту скрыт. Поставьте 1 только для отладки на проде.
#
# Почта
#   Либо RuSender: RUSENDER_API_KEY + MAIL_FROM (см. код mail.js), либо SMTP. Для отладки без отправки: MAIL_MODE=console.
#   Пароль SMTP можно задать как SMTP_PASS или SMTP_PASSWORD. Пустой SMTP_PASS — письма не уйдут (в логе будет ошибка SMTP).
#
# Дополнительно (редко)
#   BOOKING_CORS_ORIGIN — устаревшее имя; сервер читает его как второй список origins (как CORS_ORIGINS). Лучше перейти на CORS_ORIGINS.
#   CSP_ENABLED — CSP Helmet: в production включено по умолчанию; локально CSP_ENABLED=1 чтобы включить.
#   SESSION_COOKIE_SAMESITE, SESSION_COOKIE_DOMAIN — тонкая настройка cookie.
#   LISTEN_HOST — по умолчанию 0.0.0.0.
#   PGSSL_REJECT_UNAUTHORIZED=0 — если TLS к Postgres ругается на сертификат.
#   MAIL_MODE=console — логировать письма вместо отправки.
#
# Ассистент (опционально)
#   OPENROUTER_API_KEY — без ключа чат ассистента недоступен.
#   ASSISTANT_MODEL, ASSISTANT_TIMEZONE, ASSISTANT_MAX_OUTPUT_TOKENS, OPENROUTER_HTTP_REFERER, OPENROUTER_APP_TITLE, ASSISTANT_DISABLED
#
# ЮKassa (подписка)
#   YOOKASSA_SHOP_ID / YOOKASSA_SECRET_KEY — тестовые или боевые ключи магазина.
#   YOOKASSA_RETURN_URL — куда вернуть пользователя после оплаты (обычно /settings).
#   YOOKASSA_WEBHOOK_SECRET — необязательный shared secret (передайте в URL/заголовке при проксировании webhook).
#   YOOKASSA_WEBHOOK_ALLOWED_IPS — список IP через запятую для дополнительной фильтрации webhook.
#   YOOKASSA_TEST_MODE — только для явной маркировки окружения (логика API задаётся ключами магазина).
#
# Первый запуск БД: npm run db:migrate:deploy --prefix server
# Запуск фронта + API из корня репозитория: npm run dev
